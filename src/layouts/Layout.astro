---
import Head from "@components/Head.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import Pagefind from "@components/PageFind.astro";
import { SITE } from "@consts";

type Props = {
  title?: string;
  description: string;
};

const { title, description } = Astro.props;
const pageTitle = title ? `${SITE.TITLE} | ${title}` : SITE.TITLE;
---

<!doctype html>
<html lang="ru">
  <head>
    <Head title={pageTitle} description={description} />
  </head>
  <body>
    <noscript>
      <style>
        .animate{
          opacity:1;
          translate: var(--tw-translate-x) calc(var(--spacing) * 0);
        }
      </style>
    </noscript>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <Pagefind />

    <script is:inline>
      function trackView() {
        fetch('/api/v1/views', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'same-origin',
          body: JSON.stringify({ path: window.location.pathname }),
          keepalive: true,
        }).catch(() => {});
      }

      document.addEventListener('DOMContentLoaded', trackView);
      document.addEventListener('astro:after-swap', trackView);
    </script>
  </body>
</html>

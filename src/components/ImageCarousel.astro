---
interface Image {
  src: string;
  alt: string;
}

interface Props {
  images: Image[];
}

const { images } = Astro.props;
const id = `carousel-${crypto.randomUUID()}`;
---

<div
  class="image-carousel not-prose my-6"
  data-carousel={id}
  aria-roledescription="carousel"
>
  <div
    class="relative overflow-hidden rounded-lg border border-black/15 dark:border-white/20"
  >
    <div
      class="carousel-track flex snap-x snap-mandatory overflow-x-auto scroll-smooth"
      data-track
      tabindex="0"
      aria-label="Галерея изображений"
    >
      {
        images.map((image, index) => (
          <figure
            class="carousel-slide w-full shrink-0 snap-center snap-always"
            data-slide
          >
            <img
              src={image.src}
              alt={image.alt}
              width="1080"
              height="1920"
              class="mx-auto block h-auto max-h-[min(70vh,640px)] w-full object-contain bg-neutral-200/40 dark:bg-neutral-800/40"
              loading={index === 0 ? "eager" : "lazy"}
              decoding="async"
            />
          </figure>
        ))
      }
    </div>

    {
      images.length > 1 && (
        <>
          <button
            type="button"
            class="absolute top-1/2 left-2 z-10 grid size-9 -translate-y-1/2 place-content-center rounded-sm border border-black/15 bg-neutral-100/90 text-black/75 backdrop-blur-xs transition-colors duration-300 ease-in-out hover:bg-neutral-100 hover:text-black sm:left-3 dark:border-white/20 dark:bg-neutral-900/90 dark:text-white/75 dark:hover:bg-neutral-900 dark:hover:text-white"
            data-prev
            aria-label="Предыдущее изображение"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="size-5"
              aria-hidden="true"
            >
              <path d="m15 18-6-6 6-6" />
            </svg>
          </button>
          <button
            type="button"
            class="absolute top-1/2 right-2 z-10 grid size-9 -translate-y-1/2 place-content-center rounded-sm border border-black/15 bg-neutral-100/90 text-black/75 backdrop-blur-xs transition-colors duration-300 ease-in-out hover:bg-neutral-100 hover:text-black sm:right-3 dark:border-white/20 dark:bg-neutral-900/90 dark:text-white/75 dark:hover:bg-neutral-900 dark:hover:text-white"
            data-next
            aria-label="Следующее изображение"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="size-5"
              aria-hidden="true"
            >
              <path d="m9 18 6-6-6-6" />
            </svg>
          </button>
        </>
      )
    }
  </div>

  {
    images.length > 1 && (
      <div class="mt-3 flex items-center justify-center gap-2" data-dots>
        {
          images.map((image, index) => (
            <button
              type="button"
              class="carousel-dot size-2 rounded-full bg-black/20 transition-colors duration-300 ease-in-out hover:bg-black/40 data-[active=true]:bg-black/60 dark:bg-white/25 dark:hover:bg-white/50 dark:data-[active=true]:bg-white/70"
              data-dot={index}
              data-active={index === 0 ? "true" : "false"}
              aria-label={`Слайд ${index + 1}: ${image.alt}`}
              aria-current={index === 0 ? "true" : undefined}
            />
          ))
        }
      </div>
    )
  }
</div>

<style>
  .carousel-track {
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .carousel-track::-webkit-scrollbar {
    display: none;
  }
</style>

<script>
  const initCarousels = () => {
    document.querySelectorAll<HTMLElement>("[data-carousel]").forEach((carousel) => {
      if (carousel.dataset.initialized === "true") return;
      carousel.dataset.initialized = "true";

      const track = carousel.querySelector<HTMLElement>("[data-track]");
      const slides = carousel.querySelectorAll<HTMLElement>("[data-slide]");
      const prevBtn = carousel.querySelector<HTMLButtonElement>("[data-prev]");
      const nextBtn = carousel.querySelector<HTMLButtonElement>("[data-next]");
      const dots = carousel.querySelectorAll<HTMLButtonElement>("[data-dot]");

      if (!track || slides.length <= 1) return;

      let currentIndex = 0;

      const updateDots = () => {
        dots.forEach((dot, index) => {
          const isActive = index === currentIndex;
          dot.dataset.active = isActive ? "true" : "false";
          dot.setAttribute("aria-current", isActive ? "true" : "false");
        });
      };

      const scrollToIndex = (index: number) => {
        const slide = slides[index];
        if (!slide) return;

        currentIndex = index;
        slide.scrollIntoView({
          behavior: "smooth",
          inline: "center",
          block: "nearest",
        });
        updateDots();
      };

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;

            const index = Array.from(slides).indexOf(entry.target as HTMLElement);
            if (index === -1) return;

            currentIndex = index;
            updateDots();
          });
        },
        { root: track, threshold: 0.6 },
      );

      slides.forEach((slide) => observer.observe(slide));

      prevBtn?.addEventListener("click", () => {
        scrollToIndex((currentIndex - 1 + slides.length) % slides.length);
      });

      nextBtn?.addEventListener("click", () => {
        scrollToIndex((currentIndex + 1) % slides.length);
      });

      dots.forEach((dot) => {
        dot.addEventListener("click", () => {
          const index = Number(dot.dataset.dot);
          if (!Number.isNaN(index)) scrollToIndex(index);
        });
      });

      track.addEventListener("keydown", (event) => {
        if (event.key === "ArrowLeft") {
          event.preventDefault();
          scrollToIndex((currentIndex - 1 + slides.length) % slides.length);
        }

        if (event.key === "ArrowRight") {
          event.preventDefault();
          scrollToIndex((currentIndex + 1) % slides.length);
        }
      });
    });
  };

  document.addEventListener("astro:page-load", initCarousels);
  initCarousels();
</script>
